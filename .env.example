# Backend API Configuration
# Copy this file to .env and update with your values

# ============================================================
# Frontend Configuration (automatically loaded by Vite)
# ============================================================
# URL of your Python backend server (used by the frontend to connect to backend)
VITE_API_URL=http://localhost:5000

# ============================================================
# Backend Configuration (for backend_server.py)
# ============================================================
# These environment variables configure the Python backend server itself
# IMPORTANT: You must manually load these before starting the backend server
# See QUICKSTART.md Step 3 for instructions on loading environment variables
#
# Quick example (macOS/Linux):
#   export $(grep -v '^#' .env | xargs) && python backend_server.py
#
# If you change BACKEND_PORT, also update VITE_API_URL above to match!
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000
BACKEND_DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production
ELECTRICITY_RATE=0.314555
SYSTEM_NAME=Home
DEVICE_CACHE_TTL=300
VERBOSE_LOGGING=false

# Sensitive values follow! Don't commit real credentials to version control!
EMPORIA_USERNAME="emporia-username"
EMPORIA_PASSWORD="emporia-password"
GAS_RTSP_URL=rtsp://username:password@ip_address:port/stream
WATER_RTSP_URL=rtsp://username:password@ip_address:port/stream
