# Backend API Configuration
# Copy this file to .env.local and update with your values

# Frontend Configuration
# URL of your Python backend server (used by the frontend to connect to backend)
VITE_API_URL=http://localhost:5000

# Backend Configuration (for backend_server.py)
# These environment variables configure the Python backend server itself
# Set these when running the backend server: python backend_server.py
BACKEND_HOST=0.0.0.0
BACKEND_PORT=5000
BACKEND_DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production
