# Backend Server Configuration
# Copy this file to .env.local and update with your values

# Host to bind the server to (default: 0.0.0.0)
BACKEND_HOST=0.0.0.0

# Port to listen on (default: 5001)
BACKEND_PORT=5001

# Enable debug mode (default: true)
BACKEND_DEBUG=true

# JWT secret key for authentication
# IMPORTANT: Change this to a secure random string in production!
SECRET_KEY=your-secret-key-change-this-in-production

# Electricity Rate Configuration
# The rate of electricity in your local currency per kilowatt-hour (kWh)
# This is used to calculate the cost of energy consumption
# Example: 0.3243 means $0.3243 per kWh
# Default: 0.3243
ELECTRICITY_RATE=0.3243
